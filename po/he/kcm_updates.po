#: kcm/ui/main.qml:40
#, kde-format
msgid "Update software:"
msgstr "עדכון תוכנה:"

#: kcm/ui/main.qml:41
#, kde-format
msgid "Manually"
msgstr "ידני"

#: kcm/ui/main.qml:51
#, kde-format
msgid "Automatically"
msgstr "אוטומטי"

#: kcm/ui/main.qml:58
#, kde-kuit-format
msgctxt "@info"
msgid ""
"Software updates will be downloaded automatically when they become "
"available. Updates for applications will be installed immediately, while "
"updates for the system will be installed the next time it’s restarted."
msgstr ""
"עדכוני התוכנה ירדו אוטומטית כשאלה זמינים. עדכונים ליישומים יותקנו מיידית, "
"בעוד שעדכוני מערכת יותקנו עם ההפעלה הבאה מחדש."

#: kcm/ui/main.qml:69
#, kde-format
msgctxt "@title:group"
msgid "Update frequency:"
msgstr "תדירות עדכון:"

#: kcm/ui/main.qml:69
#, kde-format
msgctxt "@title:group"
msgid "Notification frequency:"
msgstr "תדירות התראות:"

#: kcm/ui/main.qml:72
#, kde-format
msgctxt "@item:inlistbox"
msgid "Daily"
msgstr "יומית"

#: kcm/ui/main.qml:73
#, kde-format
msgctxt "@item:inlistbox"
msgid "Weekly"
msgstr "שבועית"

#: kcm/ui/main.qml:74
#, kde-format
msgctxt "@item:inlistbox"
msgid "Monthly"
msgstr "חודשית"

#: kcm/ui/main.qml:75
#, kde-format
msgctxt "@item:inlistbox"
msgid "Never"
msgstr "אף פעם לא"

#: kcm/ui/main.qml:119
#, kde-format
msgid "Apply system updates:"
msgstr "החלת עדכוני מערכת:"

#: kcm/ui/main.qml:126
#, kde-format
msgctxt ""
"@option:radio part of the logical sentence 'Apply system updates after "
"rebooting'"
msgid "After rebooting"
msgstr "לאחר הפעלה מחדש"

#: kcm/ui/main.qml:133
#, kde-format
msgctxt ""
"@label The thing being recommended is to use the 'apply updates when "
"rebooting' setting"
msgid "Recommended to maximize system stability"
msgstr "מומלץ כדי לשפר את יציבות המערכת"

#: kcm/ui/main.qml:139
#, kde-format
msgctxt ""
"@option:radio part of the logical sentence 'Apply system updates immediately'"
msgid "Immediately"
msgstr "מיידית"
